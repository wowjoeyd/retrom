{
  "catalog_id": "xemu",
  "display_name": "xemu",
  "description": "Original Xbox emulator",
  "supported_platform_folder_names": ["xbox"],
  "operating_systems": ["WINDOWS", "MACOS", "LINUX_X86_64"],
  "installable": true,
  "deprecated": false,
  "default_profile": {
    "name": "Default",
    "supported_extensions": ["iso", "xbe"],
    "custom_args": ["{file}"]
  },
  "targets": [
    {
      "operating_system": "WINDOWS",
      "upstream": {
        "type": "github_release",
        "repo": "xemu-project/xemu",
        "asset_pattern": "xemu-[0-9.]+-windows-x86_64\\.zip",
        "manifest_version_from": "tag"
      },
      "install": {
        "archive_type": "zip",
        "strip_components": 0,
        "executable_relative_path": "xemu.exe",
        "preserve_paths": ["eeprom.bin", "hdd/"]
      }
    },
    {
      "operating_system": "MACOS",
      "upstream": {
        "type": "github_release",
        "repo": "xemu-project/xemu",
        "asset_pattern": "xemu-[0-9.]+-macos-universal\\.zip",
        "manifest_version_from": "tag"
      },
      "install": {
        "archive_type": "zip",
        "strip_components": 0,
        "executable_relative_path": "xemu.app/Contents/MacOS/xemu",
        "preserve_paths": ["eeprom.bin", "hdd/"]
      }
    },
    {
      "operating_system": "LINUX_X86_64",
      "upstream": {
        "type": "github_release",
        "repo": "xemu-project/xemu",
        "asset_pattern": "xemu-[0-9.]+-x86_64\\.AppImage",
        "manifest_version_from": "tag"
      },
      "install": {
        "archive_type": "appimage",
        "strip_components": 0,
        "executable_glob": "xemu*.AppImage",
        "preserve_paths": ["eeprom.bin", "hdd/"]
      }
    }
  ]
}
