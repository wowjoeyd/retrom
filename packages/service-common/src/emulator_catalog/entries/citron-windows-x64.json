{
  "catalog_id": "citron",
  "display_name": "Citron",
  "description": "Nintendo Switch emulator (deprecated/unmaintained fork)",
  "supported_platform_folder_names": ["switch"],
  "operating_systems": ["WINDOWS", "LINUX_X86_64"],
  "installable": true,
  "deprecated": true,
  "legal_notice": "Citron is no longer maintained. You may encounter bugs, compatibility issues, or missing fixes, and it is not recommended unless you specifically need this fork.",
  "default_profile": {
    "name": "Default",
    "supported_extensions": ["nsp", "xci", "nca"],
    "custom_args": ["{file}"]
  },
  "targets": [
    {
      "operating_system": "WINDOWS",
      "upstream": {
        "type": "github_release",
        "repo": "citron-neo/emulator",
        "asset_pattern": "Citron-windows-nightly-.*-x64-msvc\\.zip",
        "manifest_version_from": "tag"
      },
      "install": {
        "archive_type": "zip",
        "strip_components": 0,
        "executable_relative_path": "citron.exe",
        "preserve_paths": ["user/", "nand/", "sdmc/"],
        "internal_install_supported": true
      }
    },
    {
      "operating_system": "LINUX_X86_64",
      "upstream": {
        "type": "github_release",
        "repo": "citron-neo/emulator",
        "asset_pattern": "citron_nightly-.*-linux-x86_64\\.AppImage",
        "manifest_version_from": "tag"
      },
      "install": {
        "archive_type": "appimage",
        "strip_components": 0,
        "executable_glob": "Citron-*.AppImage",
        "preserve_paths": ["user/", "nand/", "sdmc/"]
      }
    }
  ]
}
