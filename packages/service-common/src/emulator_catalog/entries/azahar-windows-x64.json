{
  "catalog_id": "azahar",
  "display_name": "Azahar",
  "description": "Nintendo 3DS emulator (Citra-lineage fork)",
  "supported_platform_folder_names": ["3ds"],
  "operating_systems": ["WINDOWS"],
  "installable": true,
  "deprecated": false,
  "default_profile": {
    "name": "Default",
    "supported_extensions": ["3ds", "cia", "cxi", "app"],
    "custom_args": ["{file}"]
  },
  "targets": [
    {
      "operating_system": "WINDOWS",
      "upstream": {
        "type": "github_release",
        "repo": "azahar-emu/azahar",
        "asset_pattern": "azahar-windows-msvc-.*\\.zip",
        "manifest_version_from": "tag"
      },
      "install": {
        "archive_type": "zip",
        "strip_components": 0,
        "executable_relative_path": "azahar.exe",
        "preserve_paths": ["user/", "nand/", "sdmc/"]
      }
    }
  ]
}