{
  "catalog_id": "snes9x",
  "display_name": "Snes9x",
  "description": "Super Nintendo / Super Famicom emulator",
  "supported_platform_folder_names": ["snes", "sfc"],
  "operating_systems": ["WINDOWS", "MACOS", "LINUX_X86_64"],
  "installable": true,
  "deprecated": false,
  "default_profile": {
    "name": "Default",
    "supported_extensions": ["sfc", "smc", "swc", "fig", "bs", "st"],
    "custom_args": ["{file}"]
  },
  "targets": [
    {
      "operating_system": "WINDOWS",
      "upstream": {
        "type": "github_release",
        "repo": "snes9xgit/snes9x",
        "asset_pattern": "snes9x-.*-win32-x64\\.zip",
        "manifest_version_from": "tag"
      },
      "install": {
        "archive_type": "zip",
        "strip_components": 0,
        "executable_glob": "snes9x*.exe",
        "preserve_paths": []
      }
    },
    {
      "operating_system": "MACOS",
      "upstream": {
        "type": "github_release",
        "repo": "snes9xgit/snes9x",
        "asset_pattern": "Snes9x-.*-Mac\\.zip",
        "manifest_version_from": "tag"
      },
      "install": {
        "archive_type": "zip",
        "strip_components": 0,
        "executable_relative_path": "Snes9x.app/Contents/MacOS/Snes9x",
        "preserve_paths": []
      }
    },
    {
      "operating_system": "LINUX_X86_64",
      "upstream": {
        "type": "github_release",
        "repo": "snes9xgit/snes9x",
        "asset_pattern": "Snes9x-.*-x86_64\\.AppImage",
        "manifest_version_from": "tag"
      },
      "install": {
        "archive_type": "appimage",
        "strip_components": 0,
        "executable_glob": "Snes9x*.AppImage",
        "preserve_paths": []
      }
    }
  ]
}
