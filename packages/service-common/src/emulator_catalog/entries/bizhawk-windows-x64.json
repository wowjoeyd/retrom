{
  "catalog_id": "bizhawk",
  "display_name": "BizHawk",
  "description": "Multi-system emulator for NES, SNES, GB, GBA, Genesis, N64, and more",
  "supported_platform_folder_names": [
    "nes",
    "snes",
    "gb",
    "gbc",
    "gba",
    "genesis",
    "megadrive",
    "n64",
    "psx",
    "ps1"
  ],
  "operating_systems": ["WINDOWS", "LINUX_X86_64"],
  "installable": true,
  "deprecated": false,
  "default_profile": {
    "name": "Default",
    "supported_extensions": [
      "nes",
      "fds",
      "sfc",
      "smc",
      "gb",
      "gbc",
      "gba",
      "md",
      "gen",
      "n64",
      "z64",
      "v64",
      "bin",
      "cue",
      "iso"
    ],
    "custom_args": ["--open", "{file}"]
  },
  "targets": [
    {
      "operating_system": "WINDOWS",
      "upstream": {
        "type": "github_release",
        "repo": "TASEmulators/BizHawk",
        "asset_pattern": "BizHawk-.*-win-x64\\.zip",
        "manifest_version_from": "tag"
      },
      "install": {
        "archive_type": "zip",
        "strip_components": 0,
        "executable_relative_path": "EmuHawk.exe",
        "preserve_paths": ["config.ini", "Firmware/", "Movies/", "SaveRAM/", "SaveStates/", "Shaders/"]
      }
    },
    {
      "operating_system": "LINUX_X86_64",
      "upstream": {
        "type": "github_release",
        "repo": "TASEmulators/BizHawk",
        "asset_pattern": "BizHawk-.*-linux-x64\\.tar\\.gz",
        "manifest_version_from": "tag"
      },
      "install": {
        "archive_type": "tar_gz",
        "strip_components": 0,
        "executable_relative_path": "EmuHawkMono.sh",
        "preserve_paths": ["config.ini", "Firmware/", "Movies/", "SaveRAM/", "SaveStates/", "Shaders/"]
      }
    }
  ]
}
